{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "KPassword",
    "version":  "0.3.1",
    "identifier":  "com.mns.kpassword",
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "devUrl":  "http://localhost:1420",
                  "beforeBuildCommand":  "npm run build",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "KPassword",
                                    "width":  1100,
                                    "height":  720,
                                    "minWidth":  900,
                                    "minHeight":  620,
                                    "resizable":  true,
                                    "fullscreen":  false,
                                    "decorations":  false,
                                    "center":  true
                                }
                            ],
                "security":  {
                                 "csp":  null
                             }
            },
    "bundle":  {
                   "active":  true,
                   "createUpdaterArtifacts":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ],
                   "windows":  {
                                   "nsis":  {
                                                "installerIcon":  "icons/icon.ico",
                                                "uninstallerIcon":  "icons/icon.ico"
                                            }
                               }
               },
    "plugins":  {
                    "updater":  {
                                    "pubkey":  "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY4NzYxNERBQzREQTJBRkIKUldUN0t0ckUyaFIyK05wSzFlNkdFNTRVekpwY3B2M05FcmhuRlpSWGNldks3WWNKcDdRWUx4ekUK",
                                    "endpoints":  [
                                                      "https://github.com/JeanMSilvaKyndryl/KPassword/releases/latest/download/latest.json"
                                                  ],
                                    "windows":  {
                                                    "installMode":  "passive"
                                                }
                                }
                }
}
